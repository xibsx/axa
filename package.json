  "repository": {
    "type": "git",
    "url": "https://github.com/xibs/sams.git"
  },
  "dependencies": {
    "express": "^4.18.2",
    "cors": "^2.8.5",
    "dotenv": "^16.0.3",
    "bcryptjs": "^2.4.3",
    "jsonwebtoken": "^9.0.0",
    "multer": "^1.4.5-lts.1",
    "helmet": "^7.0.0",
    "compression": "^1.7.4",
    "express-rate-limit": "^6.7.0",
    "node-fetch": "^2.6.9",
    "fs-extra": "^11.1.1",
    "path": "^0.12.7",
    "moment": "^2.29.4",
    "moment-timezone": "^0.5.43",
