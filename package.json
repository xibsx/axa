{
  "name": "sams",
  "version": "1.0.0",
  "description": "Student Attendance Management System - Offline-first PWA with location verification",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "test": "echo \"Error: no test specified\" && exit 1",
    "backup": "node scripts/backup.js",
    "sync": "node scripts/sync.js",
    "deploy": "pm2 start server.js --name sams",
    "stop": "pm2 stop sams",
    "logs": "pm2 logs sams"
  },
  "keywords": [
    "attendance",
    "education",
    "pwa",
    "offline-first",
    "location",
    "school",
    "tanzania"
  ],
