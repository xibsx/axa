# Server
PORT=3000
NODE_ENV=production

# API Keys
WHATSAPP_API=https://wa-api.nior.space/api/send
JWT_SECRET=your-super-secret-jwt-key-change-this
ENCRYPTION_KEY=your-32-character-encryption-key

# Database (JSON paths)
DATA_PATH=./data/json
BACKUP_PATH=./data/json/backup

# Timezone
TIMEZONE=Africa/Dar_es_Salaam

# Rate Limiting
RATE_LIMIT_WINDOW=15
RATE_LIMIT_MAX=100

# Backup Schedule (cron)
BACKUP_CRON=0 2 * * *

# Admin Contacts
ADMIN_EMAIL=admin@sams.com
ADMIN_WHATSAPP=+255123456789

# Feature Flags
ENABLE_WHATSAPP=true
ENABLE_BACKUP=true
ENABLE_RATE_LIMIT=true
